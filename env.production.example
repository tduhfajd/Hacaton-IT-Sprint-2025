# Production Environment Variables Example
# Copy this to .env.production and update values

# Node Environment
NODE_ENV=production

# Database
DATABASE_URL=postgresql://user:pass@db:5432/smart_assistant
POSTGRES_DB=smart_assistant
POSTGRES_USER=user
POSTGRES_PASSWORD=StrongPasswordChange2025!

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=your-very-strong-secret-key-change-in-production-2025
JWT_REFRESH_SECRET=your-very-strong-refresh-secret-key-change-in-production-2025
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# GigaChat API
GIGACHAT_CLIENT_ID=4564de21-0d1d-4524-b4e7-cc807691ea32
GIGACHAT_AUTH_KEY=NDU2NGRlMjEtMGQxZC00NTI0LWI0ZTctY2M4MDc2OTFlYTMyOmU4YmVhZGUwLWEzY2MtNDIzMC05N2Q3LWQxOGY4ODcyMmQzMw==

# API URLs
API_URL=https://api-smartsupport.vadimevgrafov.ru
FRONTEND_URL=https://user-smartsupport.vadimevgrafov.ru

# CORS Origins
