# Smart Assistant for Citizen Appeals - .gitattributes

# ===========================================
# Text Files
# ===========================================
# Ensure consistent line endings
*.md text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.xml text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.py text eol=lf
*.sql text eol=lf

# ===========================================
# Binary Files
# ===========================================
# Treat these as binary
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary
*.zip binary
*.rar binary
*.7z binary
*.tar.gz binary
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.bmp binary
*.tiff binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp4 binary
*.avi binary
*.mov binary
*.mp3 binary
*.wav binary

# ===========================================
# Git LFS (if needed)
# ===========================================
# Large files to be stored in Git LFS
# *.psd filter=lfs diff=lfs merge=lfs -text
# *.ai filter=lfs diff=lfs merge=lfs -text
# *.sketch filter=lfs diff=lfs merge=lfs -text
# *.fig filter=lfs diff=lfs merge=lfs -text

# ===========================================
# Language Specific
# ===========================================
# JavaScript/TypeScript
*.js linguist-language=JavaScript
*.jsx linguist-language=JavaScript
*.ts linguist-language=TypeScript
*.tsx linguist-language=TypeScript

# Python
*.py linguist-language=Python

# Shell scripts
*.sh linguist-language=Shell
*.bash linguist-language=Shell

# SQL
*.sql linguist-language=SQL

# YAML
*.yaml linguist-language=YAML
*.yml linguist-language=YAML

# JSON
*.json linguist-language=JSON

# Markdown
*.md linguist-language=Markdown

# ===========================================
# Documentation
# ===========================================
# Documentation files
README.md linguist-documentation
CHANGELOG.md linguist-documentation
LICENSE linguist-documentation
CONTRIBUTING.md linguist-documentation
*.md linguist-documentation

# ===========================================
# Generated Files
# ===========================================
# Generated files that should not be counted in language stats
package-lock.json linguist-generated
yarn.lock linguist-generated
*.min.js linguist-generated
*.min.css linguist-generated
*.bundle.js linguist-generated
*.chunk.js linguist-generated

# ===========================================
# Diff Settings
# ===========================================
# Files that should not be diffed
*.log -diff
*.cache -diff
*.tmp -diff
*.temp -diff

# ===========================================
# Merge Settings
# ===========================================
# Files that should not be merged
package-lock.json merge=ours
yarn.lock merge=ours
*.lock merge=ours

# ===========================================
# Export Settings
# ===========================================
# Files to exclude from archives
.gitattributes export-ignore
.gitignore export-ignore
.gitignore-README.md export-ignore
.env.example export-ignore
gigachat-config.example.json export-ignore