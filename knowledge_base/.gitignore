# Knowledge Base .gitignore

# Large binary files (keep structure, ignore content)
*.pdf
*.doc
*.docx
*.xls
*.xlsx
*.ppt
*.pptx
*.zip
*.rar
*.7z
*.tar.gz

# Backup files
*.backup
*.bak
*.old
*~

# Temporary files
*.tmp
*.temp
*.swp
*.swo

# Cache files
.cache/
cache/

# Logs
*.log

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Keep important structure files
!documents.jsonl
!chunks.jsonl
!manual/
!categories/
!*.md

# Ignore large media files
*.mp4
*.avi
*.mov
*.mp3
*.wav
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tiff

# Keep examples
!example-*
!sample-*